# PostgreSQL on Neon — use the *pooled* connection string from the Neon dashboard
# (host usually contains "-pooler"). Required: sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Required for Playwright (`npm run test:e2e`). Must be a dedicated Postgres DB or Neon
# branch — the suite runs `prisma migrate reset --force` before every run and must never
# point at production or your primary dev database.
TEST_DATABASE_URL=""

NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
# Comma-separated emails that may access /admin (staff). Case-insensitive.
# Leave empty to disable admin UI for everyone.
ADMIN_EMAILS=""
# Ops workers: comma-separated emails for /worker (workflow, drafts, uploads).
# Separate from ADMIN_EMAILS; payment totals are hidden there.
WORKER_EMAILS=""
# Leave NEXTAUTH_URL unset in dev — AUTH_TRUST_HOST lets NextAuth derive
# the origin from the request, so the app works on any dev port.
# Set NEXTAUTH_URL only in production (e.g. https://app.example.com).
AUTH_TRUST_HOST=true
# NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Transactional email (Resend): https://resend.com — required in production for
# sign-up verification and password reset. In dev, if unset, new accounts are
# auto-verified (email is not sent).
RESEND_API_KEY=""
# Must be a verified sender/domain in Resend (see their dashboard).
EMAIL_FROM="WeBroker <onboarding@resend.dev>"

# --- Docker (see docker-compose.yml + Dockerfile) ---
# Run the full stack (web + Postgres): docker compose up --build
# Before first request, push schema to the compose DB (from host; port 5432 exposed):
#   DATABASE_URL="postgresql://webroker:webroker@127.0.0.1:5432/webroker?sslmode=disable" npm run db:push
# Production image only (e.g. Neon): docker build -t webroker . && docker run -p 3000:3000 -e DATABASE_URL=... -e NEXTAUTH_SECRET=... -e NEXTAUTH_URL=https://your-domain webroker
#
# If host port 3000 is busy (common when `next dev` runs):
#   WEB_PORT=3001 NEXTAUTH_URL=http://localhost:3001 docker compose up --build
# Or: npm run docker:up:3001
#
# --- Payments (production) ---
# mock = simulated checkout (dev / tests). razorpay = real orders + webhooks.
PAYMENT_PROVIDER="mock"
# Allow success/failure simulation outside dev (required for Playwright E2E in production mode).
# ENABLE_PAYMENT_SIMULATE="true"
#
# Razorpay — use Dashboard → API Keys (Test mode): rzp_test_… / secret.
# Webhook secret is only required for POST /api/webhooks/razorpay (not for checkout in dev).
# PAYMENT_PROVIDER="razorpay"
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""
# Dashboard webhook URL: https://YOUR_DOMAIN/api/webhooks/razorpay  (event: payment.captured)

# --- Rate limiting (recommended in production) ---
# Upstash Redis REST — https://upstash.com — used by middleware for /api/sign-up, password reset, etc.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# --- Workflow ---
# When true, customers cannot POST /api/agreements/:id/status (use admin or provider jobs).
# DISABLE_PUBLIC_AGREEMENT_STATUS_ADVANCE="true"
