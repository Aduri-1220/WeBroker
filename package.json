{
  "name": "webroker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "node scripts/debug-next-chunks.mjs --repair",
    "predev:webpack": "node scripts/debug-next-chunks.mjs --repair",
    "predev:turbo": "node scripts/debug-next-chunks.mjs --repair",
    "predev:plain": "node scripts/debug-next-chunks.mjs --repair",
    "predev:clean": "node scripts/debug-next-chunks.mjs --repair",
    "dev": "sh -c 'ulimit -n 65536 2>/dev/null || ulimit -n 10240 2>/dev/null; export CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=2000; exec ./node_modules/.bin/next dev --turbo'",
    "dev:webpack": "sh -c 'ulimit -n 65536 2>/dev/null || ulimit -n 10240 2>/dev/null; export CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=2000; exec ./node_modules/.bin/next dev'",
    "dev:clean": "sh -c 'ulimit -n 65536 2>/dev/null || ulimit -n 10240 2>/dev/null; export CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=2000; rm -rf .next && exec ./node_modules/.bin/next dev --turbo'",
    "dev:turbo": "next dev --turbo",
    "dev:plain": "next dev --turbo",
    "dev:serve": "next build && next start",
    "debug:chunks": "node scripts/debug-next-chunks.mjs",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "next lint && npm run format:check",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:ensure-columns": "node scripts/ensure-db-columns.cjs",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "docker:build": "docker build -t webroker .",
    "docker:up": "docker compose up --build",
    "docker:up:3001": "WEB_PORT=3001 NEXTAUTH_URL=http://localhost:3001 docker compose up --build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.20.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.453.0",
    "next": "14.2.15",
    "next-auth": "^4.24.8",
    "react": "^18.3.1",
    "react-day-picker": "^10.0.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.3",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.47",
    "prettier": "^3.4.2",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^4.1.6"
  }
}
